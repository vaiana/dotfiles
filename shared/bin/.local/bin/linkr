#!/bin/bash

# Path to your list
LIST_FILE="$HOME/.config/linkr/config"

if [ -z "$1" ]; then
    # --- DISPLAY MODE ---
    # 1. -F '|': Set delimiter to pipe
    # 2. /^[ \t]*#/ : Regex to match lines starting with # (even with spaces before it)
    # 3. next : Skip those lines
    # 4. NF : Ensure line is not empty
    # 5. print $1 : Print the Name
    awk -F ';' '/^[ \t]*#/ {next} NF {print $1}' "$LIST_FILE"

else
    # --- EXECUTE MODE ---
    selection="$1"
    
    # 1. Find the line in the file
    # We must also grep out comments here just in case a command name starts with # (unlikely but safe)
    line=$(grep "^$selection;" "$LIST_FILE" | grep -v "^[ \t]*#" | head -n 1)
    
    # 2. Extract the command (field 2)
    command=$(echo "$line" | cut -d';' -f2)

    # 3. Run it
    if [ -n "$command" ]; then
        if [ -f "$HOME/.profile" ]; then source "$HOME/.profile"; fi
        eval "$command" >/dev/null 2>&1 &
    fi
fi
