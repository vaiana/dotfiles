#!/bin/bash
pw_file="$HOME/.bw_master"
if [ ! -f "$pw_file" ]; then
    osascript -e 'display notification "Missing ~/.bw_master" with title "bw-type-password"'
    exit 1
fi
# Wait for the user to release the triggering modifiers (alt-shift) before
# typing — characters sent while modifiers are still held get combined with
# them ("s" + held alt-shift would fire the screenshot hotkey, etc.).
sleep 0.5
pw=$(tr -d '\n' < "$pw_file")
cliclick t:"$pw"
