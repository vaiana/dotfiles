#!/bin/bash
set -euo pipefail
pw_file="$HOME/.bw_master"
if [ ! -f "$pw_file" ]; then
    osascript -e 'display notification "Missing ~/.bw_master" with title "bw-type-password"'
    exit 1
fi

# Wait for the triggering modifiers (alt-cmd) to release before sending Cmd+V,
# otherwise they get folded into the synthetic keystroke.
sleep 0.5

# Stage on the clipboard, paste with Cmd+V, then restore the prior clipboard.
# Paste events (vs. synthesized character typing) work reliably in browser
# password fields.
prev=$(pbpaste 2>/dev/null || true)
tr -d '\n' < "$pw_file" | pbcopy
osascript -e 'tell application "System Events" to keystroke "v" using command down'
sleep 0.3
printf '%s' "$prev" | pbcopy
