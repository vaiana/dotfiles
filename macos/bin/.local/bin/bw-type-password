#!/bin/bash
pw_file="$HOME/.bw_master"
if [ ! -f "$pw_file" ]; then
    osascript -e 'display notification "Missing ~/.bw_master" with title "bw-type-password"'
    exit 1
fi
sleep 0.2
pw=$(tr -d '\n' < "$pw_file")
osascript - "$pw" <<'EOF'
on run argv
    tell application "System Events" to keystroke (item 1 of argv)
end run
EOF
